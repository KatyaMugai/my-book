<header class="site-header">
  <h1 class="site-title">Romanzo Animal farm</h1>
  <p class="site-slogan">Book by George Orwell</p>
</header>
<!DOCTYPE html>
<html>
<head>
  <style>
    .book-title {
      font-weight: bold;          /* жирный / bold */
    }
    .author {
      text-decoration: underline; /* подчёркнутый / underlined */
    }
    .foreign-title {
      font-style: italic;         /* курсив / italic */
    }
  </style>
</head>
<body>

<p>
  The book <span class="book-title">Animal Farm</span> was written by 
  <span class="author">George Orwell</span>. 
  In French, it is known as 
  <span class="foreign-title">La Ferme des animaux</span>.
</p>

<!-- Example with Spanish instead -->
<p>
  The book <span class="book-title">Animal Farm</span> was written by 
  <span class="author">George Orwell</span>. 
  In Spanish, it is known as 
  <span class="foreign-title">Rebelión en la granja</span>.
</p>

</body>
</html>
<!DOCTYPE html>
<html>
<head>
  <style>
    .book-cover {
      width: 200px;
      height: 250px;
      object-fit: cover;          /* Keeps proportions, crops if needed — prevents distortion */
      border: 4px solid #444;
      border-radius: 10px;
      box-shadow: 0 6px 12px rgba(0,0,0,0.25);
      margin: 20px auto;
      display: block;
    }
  </style>
</head>
<body>

<p>
  The book <strong>Animal Farm</strong> was written by 
  <u>George Orwell</u>. 
  In French, it is known as 
  <em>La Ferme des animaux</em>.
</p>

